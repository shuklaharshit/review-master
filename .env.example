# Review Master — environment configuration
#
# Copy this file to `.env` and fill in the values. The .env file is loaded in
# development (see src/main/loadEnv.ts) and is git-ignored.

# GitHub App "Client ID" used for the device-flow login (see ADR-0007).
#
# This is a PUBLIC identifier, not a secret — there is intentionally no client
# secret and no private key (device flow doesn't need them). Get it by
# registering a GitHub App:
#   GitHub → Settings → Developer settings → GitHub Apps → New GitHub App
#   tick "Enable Device Flow" + "Expire user authorization tokens", set the
#   least-privilege repository permissions, then copy the Client ID.
# Format looks like "Iv23..." . Required — no value is committed to source; set
# it here for dev (and inject it for packaged builds).
REVIEW_MASTER_GITHUB_CLIENT_ID=Iv23your_client_id_here

# GitHub App slug — the `<slug>` in https://github.com/apps/<slug>. Used to send
# users to GitHub to install the App and pick which repositories it can access.
REVIEW_MASTER_GITHUB_APP_SLUG=your-app-slug
