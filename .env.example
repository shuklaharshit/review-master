# Review Master — environment configuration
#
# Copy this file to `.env` and fill in the values. The .env file is loaded in
# development (see src/main/loadEnv.ts) and is git-ignored.

# GitHub OAuth App "Client ID" used for the device-flow login.
#
# This is a PUBLIC identifier, not a secret — there is intentionally no client
# secret (device flow doesn't need one). Get it by registering an OAuth app:
#   GitHub → Settings → Developer settings → OAuth Apps → New OAuth App
#   then edit the app and tick "Enable Device Flow", and copy the Client ID.
# Format looks like "Iv1.0123456789abcdef" (or a newer "Iv23..." id).
REVIEW_MASTER_GITHUB_CLIENT_ID=Iv1.your_client_id_here
